<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base app theme (no action bar, DayNight aware) -->
    <style name="Theme.Gymprint" parent="Theme.AppCompat.DayNight.NoActionBar" />

    <!-- Splash screen theme — transitions to Theme.Gymprint after launch -->
    <style name="Theme.Gymprint.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#6750A4</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="windowSplashScreenIconBackgroundColor">#6750A4</item>
        <item name="postSplashScreenTheme">@style/Theme.Gymprint</item>
    </style>

</resources>
